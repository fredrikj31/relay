{
  "name": "relay",
  "type": "module",
  "scripts": {
    "app:build": "pnpm run --filter @relay/app build",
    "app:build:check": "pnpm run --filter @relay/app build:check",
    "app:dev": "pnpm run --filter @relay/app dev",
    "app:lint": "pnpm run --filter @relay/app lint",
    "app:format:check": "pnpm run --filter @relay/app format:check",
    "app:format:write": "pnpm run --filter @relay/app format:write",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}
