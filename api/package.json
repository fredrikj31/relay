{
  "name": "@relay/api",
  "scripts": {
    "dev": "tsx watch --include src src/app.ts | pino-pretty",
    "build": "tsc -p tsconfig.build.json",
    "build:check": "tsc --noEmit",
    "start": "node build/app.js",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "fastify": "^5.8.3",
    "fastify-type-provider-zod": "^6.1.0",
    "pino": "^10.3.1",
    "slonik": "^48.13.2",
    "slonik-interceptor-field-name-transformation": "^48.13.2",
    "zod": "^4.3.6"
  }
}
